# Virtual Environments
venv/
env/
ENV/
.venv
/Include/
/Lib/
pyvenv.cfg

# Stray venv console-script shims that ended up inside the real scripts/ dir
# (a pip install once landed its Scripts/ output here instead of a proper
# venv — bare "Scripts/" would also match the real project scripts/ dir on
# Windows' case-insensitive filesystem, so ignore the shims by name instead)
scripts/*.exe
scripts/pywin32_*.py

