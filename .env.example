# ILLIP AI Configuration

# API Server
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=True

# Model Provider
# auto = Ollama (GPU) → OpenRouter → Groq → Mock
# Set openrouter to use cloud 24/7 without PC
MODEL_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# OpenRouter — 200+ models, free tier available (primary cloud provider)
# Get free key: https://openrouter.ai/keys
# Free models: meta-llama/llama-3.1-8b-instruct:free, google/gemma-2-9b-it:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Groq — fast cloud LLM (secondary fallback)
# Get free key: https://console.groq.com → API Keys → Create
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Telegram bridge (optional — leave blank to disable)
# Step 1: Message @BotFather on Telegram → /newbot → copy token
# Step 2: Paste token below → restart ILLIP → message your bot → you're owner
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=   # optional extra user IDs, comma-separated

# Notion memory sync (optional — saves memories to Notion database)
# Setup: notion.so/my-integrations → New integration → copy token
# Create DB with columns: Text (title), Project (text), Category (text)
# Share DB with integration → copy DB ID from URL
NOTION_API_KEY=
NOTION_DB_ID=

# Google Drive RAG (optional — paste Drive/Doc URL in Telegram to ingest)
# Public docs work without config. For private folder sync:
# GDRIVE_SERVICE_ACCOUNT_JSON=./data/gdrive_key.json
# GDRIVE_FOLDER_ID=your_folder_id

# Voice (optional)
WHISPER_MODEL=base         # tiny=fastest, base=balanced, small/medium=accurate
# PIPER_VOICE=./data/voices/en_US-lessac-medium.onnx  # local TTS (download from HuggingFace)

# Database
DATABASE_URL=sqlite:///./data/illip.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/logs/illip.log

# Workspace Paths (relative to project root)
DATA_DIR=./data
MEMORY_DIR=./data/memory
LOGS_DIR=./data/logs
TASKS_DIR=./data/tasks
WORKSPACES_DIR=./data/workspaces
SNAPSHOTS_DIR=./data/snapshots
