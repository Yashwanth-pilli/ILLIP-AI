# ═══════════════════════════════════════════════════════════════════════════════
# ILLIP AI — Configuration
# Copy this file to .env and fill in what you need.
# Everything is optional except the model provider of your choice.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1       # change to 0.0.0.0 to expose on your LAN
API_PORT=8000
DEBUG=false
CORS_ORIGINS=*           # comma-separated origins, or * for open

# ── Model Provider ────────────────────────────────────────────────────────────
# Pick one. auto tries local first, then falls through cloud options.
# Options: auto | ollama | openai_compat | anthropic | openrouter | groq | llamafile | airllm | mock
MODEL_PROVIDER=auto

# ── Ollama — local models (GPU/CPU, fully offline) ────────────────────────────
# Install: https://ollama.com — then: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Generic OpenAI-compatible endpoint ────────────────────────────────────────
# Use for: DeepSeek, vLLM, LM Studio, Together AI, Mistral, Perplexity, etc.
# Any service that speaks the OpenAI /v1/chat/completions API works here.
#
# Examples:
#   DeepSeek:  OPENAI_COMPAT_BASE_URL=https://api.deepseek.com
#              OPENAI_COMPAT_MODEL=deepseek-chat
#
#   vLLM:      OPENAI_COMPAT_BASE_URL=http://localhost:8000
#              OPENAI_COMPAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
#
#   LM Studio: OPENAI_COMPAT_BASE_URL=http://localhost:1234
#              (model auto-detected from running server)
#
#   Together:  OPENAI_COMPAT_BASE_URL=https://api.together.xyz
#              OPENAI_COMPAT_MODEL=meta-llama/Llama-3-8b-chat-hf
#
#   OmniRoute (free cloud models, ~1.6B tokens/month, powers `/cloud` mode):
#     1. setup.bat installs it; it auto-starts with `illip`
#     2. open http://localhost:20128 -> connect a free provider -> make a key
#     3. paste the key below, then use `/cloud on` in chat
#              OPENAI_COMPAT_BASE_URL=http://localhost:20128/v1
#              OPENAI_COMPAT_MODEL=auto
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Get key: https://console.anthropic.com
# Models: claude-sonnet-4-6 (best), claude-haiku-4-5-20251001 (fast), claude-opus-4-8 (max)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenRouter — 200+ models, free tier ───────────────────────────────────────
# Get free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Groq — fast cloud, free tier ─────────────────────────────────────────────
# Get free key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── llamafile — single-file model runner ──────────────────────────────────────
# Download a .llamafile from https://huggingface.co and run it
LLAMAFILE_URL=http://localhost:8080
LLAMAFILE_MODEL=

# ── AirLLM — large models on low VRAM ────────────────────────────────────────
# Run 70B models on a 4GB GPU via layer streaming
AIRLLM_MODEL=

# ── API Authentication (optional) ────────────────────────────────────────────
# Leave empty for local single-user mode (no auth).
# Set to enable API key auth (useful when exposing ILLIP on a server).
ILLIP_API_KEYS=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/illip.db

# ── Voice ─────────────────────────────────────────────────────────────────────
WHISPER_MODEL=base       # tiny | base | small | medium | large
# PIPER_VOICE=./data/voices/en_US-lessac-medium.onnx   # local TTS

# ── Search ────────────────────────────────────────────────────────────────────
# SearXNG: docker run -d -p 8888:8080 searxng/searxng
SEARXNG_URL=http://localhost:8888
BRAVE_API_KEY=           # https://api.search.brave.com (2000 req/month free)

# ── Sync ──────────────────────────────────────────────────────────────────────
SYNC_GIT_REMOTE=         # private git repo to push data/ backups

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=  # comma-separated Telegram user IDs (empty = owner only)

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DB_ID=

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Email (SMTP/IMAP) ─────────────────────────────────────────────────────────
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── WhatsApp via Twilio ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── n8n workflow automation ───────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=./data
MEMORY_DIR=./data/memory
LOGS_DIR=./data/logs
TASKS_DIR=./data/tasks
WORKSPACES_DIR=./data/workspaces
SNAPSHOTS_DIR=./data/snapshots

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/logs/illip.log
